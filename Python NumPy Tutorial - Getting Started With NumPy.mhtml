# get the entire memory occupied by list by multiplying length of list=20
print("Memory Taken By List :", sys.getsizeof(4)*len(my_list))

# arange() function is pretty much similar to range()
numpy_array =3D np.arange(1000)

# numpy_array.size actually give one single element=20
# when it multiplied by length of NumPy array, the entire space occupied by=
 array will be generated

print("Memory Taken By NumPy array :", numpy_array.size*numpy_array.itemsiz=
e)
